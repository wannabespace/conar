{
  "name": "@conar/proxy",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development bun --watch run ./index.ts",
    "start": "cross-env NODE_ENV=production bun run ./index.ts",
    "check-types": "tsgo",
    "test:start": "cross-env NODE_ENV=test bun --env-file=.env.test drizzle-kit migrate && cross-env NODE_ENV=test bun --env-file=.env.test run ./index.ts",
    "drizzle:generate": "cross-env NODE_ENV=development drizzle-kit generate",
    "drizzle:generate-custom": "cross-env NODE_ENV=development drizzle-kit generate --custom",
    "drizzle:migrate": "cross-env NODE_ENV=development drizzle-kit migrate",
    "better-auth:generate": "cross-env NODE_ENV=development pnpx https://pkg.pr.new/better-auth/better-auth/@better-auth/cli@6913 generate --output ./drizzle/schema/auth.ts"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "catalog:",
    "@conar/connection": "workspace:*",
    "@conar/db": "workspace:*",
    "@conar/memoize": "workspace:*",
    "@conar/shared": "workspace:*",
    "@orpc/server": "catalog:",
    "arktype": "catalog:",
    "better-auth": "catalog:",
    "hono": "catalog:",
    "ua-parser-js": "catalog:",
    "uuid": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@conar/configs": "workspace:*"
  }
}
