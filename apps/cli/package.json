    "mysql2": "catalog:",
    "open": "catalog:",
    "ora": "catalog:",
    "pg": "catalog:"
  },
  "devDependencies": {
    "@conar/api": "workspace:*",
    "@conar/configs": "workspace:*",
    "@conar/connection": "workspace:*",
    "@conar/query-proxy": "workspace:*",
    "@conar/shared": "workspace:*",
    "@orpc/server": "catalog:",
    "@types/bun": "catalog:",
    "@types/mssql": "catalog:",
    "@types/pg": "catalog:",
    "memoza": "catalog:",
    "tsdown": "catalog:",
