{
  "name": "conar",
  "version": "0.0.1",
  "description": "Conar CLI – manage and query your connections from the terminal.",
  "keywords": [
    "cli",
    "clickhouse",
    "conar",
    "database",
    "mssql",
    "mysql",
    "postgres",
    "sql"
  ],
  "homepage": "https://conar.app",
  "bugs": {
    "url": "https://github.com/wannabespace/conar/issues"
  },
  "author": {
    "name": "Wannabe Space, LLC",
    "email": "wannabespace.llc@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wannabespace/conar.git",
    "directory": "apps/cli"
  },
  "bin": {
    "conar": "./dist/index.js"
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist"
  ],
