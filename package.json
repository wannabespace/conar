{
  "private": true,
  "description": "AI-powered tool for working with Postgres, MySQL, MSSQL and Clickhouse.",
  "homepage": "https://conar.app",
  "author": {
    "name": "Wannabe Space, LLC",
    "email": "wannabespace.llc@gmail.com"
  },
  "type": "module",
  "scripts": {
    "prepare": "husky && bun scripts/sync-pnpm-versions.ts && bun scripts/setup-dev.ts",
    "postinstall": "pnpm run portless:start",
    "portless:start": "portless proxy start --tld app",
    "portless:stop": "portless proxy stop",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "test:start": "turbo run test:start",
    "dev": "turbo run dev",
    "start:api": "cd apps/api && pnpm run start",
    "start:main": "cd apps/main && pnpm run start",
    "start:app": "cd apps/app && pnpm run start",
    "start:proxy": "cd apps/proxy && pnpm run start",
    "build:main": "turbo run @conar/main#build",
    "build:app": "turbo run @conar/app#build",
    "build:todesktop": "turbo run @conar/desktop#build:todesktop",
    "build:cli": "turbo run conar#build",
    "publish": "cd apps/cli && pnpm publish --access public --no-git-checks",
    "aur:sync": "bun scripts/sync-aur-version.ts",
    "aur:sync:checksum": "bun scripts/sync-aur-version.ts --checksum",
    "drizzle:generate": "cd packages/db && pnpm run drizzle:generate",
    "drizzle:migrate": "cd packages/db && pnpm run drizzle:migrate",
    "check-types": "turbo run check-types",
    "update": "taze -r -I major",
    "docker:start": "docker compose -f docker-compose.dev.yml up -d",
    "docker:stop": "docker compose -f docker-compose.dev.yml down",
    "deps:inspect": "node-modules-inspector",
    "deps:build": "node-modules-inspector build"
  },
  "devDependencies": {
    "@conar/configs": "workspace:*",
    "@letstri/oxc-config": "catalog:",
    "@types/bun": "catalog:",
    "cross-env": "catalog:",
    "eslint-plugin-better-tailwindcss": "catalog:",
    "husky": "catalog:",
    "node-modules-inspector": "catalog:",
    "npm-run-all2": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "playwright": "catalog:",
    "portless": "catalog:",
    "tailwindcss": "catalog:",
    "taze": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "pnpm@11.10.0"
}
