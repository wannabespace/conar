{
  "$schema": "./node_modules/turbo/schema.json",
  "ui": "tui",
  "envMode": "loose",
  "tasks": {
    "start": {
      "persistent": true
    },
    "check-types": {
      "cache": false,
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "build:desktop": {
      "cache": false
    },
    "@conar/desktop#build": {
      "dependsOn": ["^@conar/app#build:desktop"],
      "cache": false
    },
    "build:todesktop": {
      "dependsOn": ["build"],
      "cache": false
    },
    "drizzle:migrate": {
      "cache": false
    },
    "drizzle:generate": {
      "cache": false
    },
    "test": {
      "cache": false
    },
    "test:e2e": {
      "cache": false
    },
    "test:start": {
      "persistent": true
    }
  }
}
